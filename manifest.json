{
    "manifest_version": 3,
    "name": "Insurance Auditor Pro",
    "version": "1.21",
    "description": "Automates insurance verification and auditing across Denticon, MetLife, and Cigna portals for dental practices.",
    "icons": {
        "16": "face-mask.png",
        "32": "protection.png",
        "48": "healthcare.png",
        "128": "healthcare (1).png"
    },
    "permissions": [
        "storage",
        "activeTab",
        "downloads"
    ],
    "host_permissions": [
        "*://*.denticon.com/*",
        "*://*.planetdds.com/*",
        "https://dentalprovider.metlife.com/*",
        "*://*.deltadental.com/*",
        "*://*.deltadentalins.com/*",
        "*://*.deltadentalva.com/*",
        "*://deltadentalva.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "face-mask.png",
            "32": "protection.png",
            "48": "healthcare.png",
            "128": "healthcare (1).png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.denticon.com/*",
                "*://*.planetdds.com/*"
            ],
            "js": [
                "content_denticon.js"
            ],
            "all_frames": true
        },
        {
            "matches": [
                "https://dentalprovider.metlife.com/*"
            ],
            "js": [
                "content_metlife.js"
            ],
            "all_frames": true
        },
        {
            "matches": [
                "https://cignaforhcp.cigna.com/*"
            ],
            "js": [
                "content_cigna.js"
            ],
            "all_frames": true
        },
        {
            "matches": [
                "*://*.deltadental.com/*",
                "*://*.deltadentalins.com/*"
            ],
            "js": [
                "content_delta_dental.js"
            ],
            "all_frames": true
        },
        {
            "matches": [
                "*://*.deltadentalva.com/*",
                "*://deltadentalva.com/*"
            ],
            "js": [
                "content_ddva.js"
            ],
            "all_frames": true
        }
    ]
}